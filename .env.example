# =============================================================================
# Heedback — Environment Configuration
# =============================================================================
# Copy this file to .env and update the values.
# All variables are required unless marked as optional.

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=heedback
POSTGRES_PASSWORD=heedback_secret
POSTGRES_DB=heedback

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=production
APP_KEY=your-random-32-character-secret-key
FRONTEND_URL=http://localhost:3000

# Port configuration (host-side)
API_PORT=3333
WEB_PORT=3000
PORTAL_PORT=3001

# -----------------------------------------------------------------------------
# Mail (via Kuriyr)
# -----------------------------------------------------------------------------
KURIYR_API_TOKEN=your-kuriyr-api-token
KURIYR_FROM_NAME=Heedback
KURIYR_FROM_EMAIL=noreply@heedback.example.com

# -----------------------------------------------------------------------------
# Storage (S3-compatible)
# -----------------------------------------------------------------------------
S3_KEY=
S3_SECRET=
S3_BUCKET=heedback
S3_REGION=us-east-1
S3_ENDPOINT=
S3_PUBLIC_URL=

# -----------------------------------------------------------------------------
# Super Admin (created on first launch)
# -----------------------------------------------------------------------------
SUPER_ADMIN_EMAIL=admin@example.com
SUPER_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# SMTP (used by Kuriyr)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# -----------------------------------------------------------------------------
# Optional
# -----------------------------------------------------------------------------
# LOG_LEVEL=info
# RATE_LIMIT_MAX=100
# SESSION_DRIVER=redis
